- switch BLU:

enable
conf t
vlan 10
exit
interface range GigabitEthernet9/1-GigabitEthernet8/1

[interface range (porta-porta)]

switchport access vlan 10
exit
interface GigabitEthernet7/1
switchport mode trunk
switchport trunk allow vlan 10

